{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"title": "Retired packages",
	"type": "array",
	"uniqueItems": true,
	"items": {
		"oneOf": [
			{
				"type": "object",
				"additionalProperties": false,
				"required": ["platform", "manager", "type", "name"],
				"properties": {
					"platform": { "const": "mac" },
					"manager": { "const": "brew" },
					"type": { "enum": ["formula", "cask"] },
					"name": { "$ref": "#/$defs/packageName" }
				}
			},
			{
				"type": "object",
				"additionalProperties": false,
				"required": ["platform", "manager", "name"],
				"properties": {
					"platform": { "const": "linux" },
					"manager": { "const": "apt" },
					"name": { "$ref": "#/$defs/packageName" }
				}
			}
		]
	},
	"$defs": {
		"packageName": {
			"type": "string",
			"pattern": "^[A-Za-z0-9][A-Za-z0-9+._:@/-]*$"
		}
	}
}
