{
	"name": "better-vscode-themes",
	"displayName": "better-vscode-themes",
	"version": "1.1.0",
	"categories": [
		"Themes"
	],
	"keywords": [
		"gruvbox",
		"theme",
		"vim"
	],
	"license": "SEE LICENSE IN LICENSE.txt",
	"repository": {
		"type": "git",
		"url": "https://github.com/theprogrammergary/.config.git"
	},
	"publisher": "gary-ix",
	"scripts": {
		"build": "vsce package && npm run install:cursor",
		"install:cursor": "ELECTRON_RUN_AS_NODE=1 \"/Applications/Cursor.app/Contents/MacOS/Cursor\" \"/Applications/Cursor.app/Contents/Resources/app/out/cli.js\" --install-extension \"./better-vscode-themes-$npm_package_version.vsix\" --force",
		"install:codium": "vsce package && codium --install-extension \"./better-vscode-themes-$npm_package_version.vsix\" --force",
		"deploy": "vsce publish"
	},
	"devDependencies": {
		"@vscode/vsce": "^3.7.0"
	},
	"contributes": {
		"themes": [
			{
				"label": "gtheme-light",
				"uiTheme": "vs",
				"path": "./themes/gtheme-light.json"
			},
			{
				"label": "gtheme-dark",
				"uiTheme": "vs-dark",
				"path": "./themes/gtheme-dark.json"
			}
		]
	},
	"icon": "icon.png",
	"engines": {
		"vscode": "^1.45.0"
	}
}
