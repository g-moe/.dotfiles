{
	"name": "dotfiles-root",
	"private": true,
	"scripts": {
		"lint": "oxlint --deny-warnings .",
		"lint:fix": "oxlint --fix --deny-warnings .",
		"format": "oxfmt .",
		"format:check": "oxfmt --check .",
		"typecheck": "tsc -b --noEmit",
		"typecheck:tsgo": "tsgo -b --noEmit",
		"skills:install": "tsx scripts/shared/install/shared-skills-setup.ts",
		"theme:install": "tsx custom-themes/create/controller.ts",
		"vscode-install": "bash scripts/shared/install/shared-vscode-setup.sh",
		"mac:install": "bash scripts/mac-install.sh",
		"linux:install": "bash scripts/linux-install.sh",
		"install:test": "bash scripts/shared/tests/shared-installer-test.sh"
	},
	"devDependencies": {
		"@types/node": "24.13.1",
		"@typescript/native-preview": "7.0.0-dev.20260607.1",
		"jsonc-parser": "3.3.1",
		"oxfmt": "0.53.0",
		"oxlint": "1.68.0",
		"tsx": "4.20.6",
		"typescript": "6.0.3"
	},
	"engines": {
		"node": ">=24 <25"
	}
}
