{
	"name": "dotfiles-root",
	"private": true,
	"scripts": {
		"lint": "oxlint --deny-warnings .",
		"lint:fix": "oxlint --fix --deny-warnings .",
		"format": "oxfmt .",
		"format:check": "oxfmt --check .",
		"typecheck": "tsc -b --noEmit",
		"typecheck:tsgo": "tsgo -b --noEmit",
		"install:git": "bash packages/installer/install.sh --git",
		"install:skills": "bash packages/installer/install.sh --skills",
		"install:theme": "bash packages/installer/install.sh --theme",
		"install:retire": "bash packages/installer/install.sh --retire",
		"install:machine": "bash packages/installer/install.sh",
		"install:test": "bash packages/installer/tests/run.sh",
		"verify:machine": "bash packages/installer/tests/repository/installed-links.sh"
	},
	"devDependencies": {
		"@types/node": "24.13.1",
		"@typescript/native-preview": "7.0.0-dev.20260607.1",
		"jsonc-parser": "3.3.1",
		"oxfmt": "0.53.0",
		"oxlint": "1.68.0",
		"tsx": "4.20.6",
		"typescript": "6.0.3"
	},
	"engines": {
		"node": ">=24 <25"
	}
}
