		"editor.insertSpaces": true
	},
	"[typescript]": {
		"editor.codeActionsOnSave": { "source.fixAll.oxc": "explicit" },
		"editor.defaultFormatter": "oxc.oxc-vscode",
		"editor.formatOnSave": true
	},
	"[javascript]": {
		"editor.codeActionsOnSave": { "source.fixAll.oxc": "explicit" },
		"editor.defaultFormatter": "oxc.oxc-vscode",
		"editor.formatOnSave": true
	},
	"[typescriptreact]": {
		"editor.codeActionsOnSave": { "source.fixAll.oxc": "explicit" },
		"editor.defaultFormatter": "oxc.oxc-vscode",
		"editor.formatOnSave": true
	},
	"[javascriptreact]": {
		"editor.codeActionsOnSave": { "source.fixAll.oxc": "explicit" },
		"editor.defaultFormatter": "oxc.oxc-vscode",
		"editor.formatOnSave": true
	},
